generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./allotwise.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("PARTNER") // ADMIN or PARTNER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]
}

model Member {
  id        String   @id @default(cuid())
  fullName  String
  panNumber String   @unique
  mobile    String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upiIds       UpiId[]
  applications Application[]
}

model UpiId {
  id        String   @id @default(cuid())
  memberId  String?
  upiId     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member       Member?       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  applications Application[]
}

model IPO {
  id         String   @id @default(cuid())
  name       String
  ipoType    String   // MAINBOARD or SME
  issuePrice Float
  lotSize    Int
  openDate   DateTime
  closeDate  DateTime
  status     String   @default("UPCOMING") // UPCOMING, OPEN, CLOSED, LISTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  applications Application[]
}

model Application {
  id              String   @id @default(cuid())
  ipoId           String
  memberId        String
  upiIdId         String
  appliedAmount   Float
  lotQuantity     Int
  applicationDate DateTime @default(now())
  status          String   @default("APPLIED") // APPLIED, ALLOTTED, NOT_ALLOTTED, REFUNDED, SOLD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ipo        IPO        @relation(fields: [ipoId], references: [id], onDelete: Cascade)
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  upiId      UpiId      @relation(fields: [upiIdId], references: [id])
  allotment  Allotment?
  activityLogs ActivityLog[]
}

model Allotment {
  id            String   @id @default(cuid())
  applicationId String   @unique
  sharesAllotted Int
  issuePrice    Float
  listingPrice  Float?
  sellPrice     Float?
  profit        Float?
  loss          Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id            String   @id @default(cuid())
  userId        String?
  applicationId String?
  action        String
  details       String?
  createdAt     DateTime @default(now())

  user        User?        @relation(fields: [userId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])
}
